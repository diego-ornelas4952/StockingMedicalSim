{
  "name": "stockingmedicalsim",
  "version": "1.0.0",
  "description": "Stocking system for the Simulators Laboratory in CUAltos (it's for my social service)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.stockingmedicalsim.app",
    "productName": "StockingMedicalSim",
    "mac": {
      "category": "public.app-category.medical"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "main.js",
      "server.js",
      "package.json",
      "interface/dist/**/*",
      "database.db"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diego-ornelas4952/StockingMedicalSim.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/diego-ornelas4952/StockingMedicalSim/issues"
  },
  "homepage": "https://github.com/diego-ornelas4952/StockingMedicalSim#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
